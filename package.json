{
  "name": "@korl3one/ccode",
  "version": "3.1.0",
  "description": "Persistent context CLI for AI-assisted development. Generates documentation, architecture, rules, and tasks — synced to Claude Code, Gemini CLI, Cursor, Copilot, and AGENTS.md.",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "ccode": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "cli",
    "context",
    "context-engineering",
    "development",
    "assistant",
    "typescript",
    "project-management",
    "documentation",
    "architecture",
    "tasks",
    "claude",
    "gemini",
    "cursor",
    "copilot",
    "agents-md",
    "llm",
    "persistent-context",
    "context-sync"
  ],
  "author": "Johannes Moreno <korl3one>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iDevelop25/ccode.git"
  },
  "homepage": "https://github.com/iDevelop25/ccode#readme",
  "bugs": {
    "url": "https://github.com/iDevelop25/ccode/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.0",
    "ora": "^8.2.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
